# ═══════════════════════════════════════════════════════
#  .env.prod.example – Production Environment Template
#  Copy to .env.prod, fill in values, NEVER commit to git
# ═══════════════════════════════════════════════════════

# ── Domain ────────────────────────────────────────────
DOMAIN=coverageops.yourdomain.com

# ── Database ──────────────────────────────────────────
DB_NAME=coverageops
DB_USER=coverageops
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD_HERE

# ── JWT / Auth ────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_LONG_RANDOM_SECRET_KEY_64_CHARS

# ── AWS (optional – only if using AWS CLI for deploys)─
AWS_REGION=il-central-1
EC2_HOST=ec2-XX-XX-XX-XX.compute.amazonaws.com
EC2_USER=ubuntu
# Path to your .pem key file (on your LOCAL machine)
EC2_KEY_FILE=~/.ssh/coverageops-key.pem
