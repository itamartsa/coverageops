# ══════════════════════════════════════════════════════════════
#  CoverageOps – Environment Variables
#  Copy this file to .env and fill in all values before running
# ══════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_LONG_RANDOM_STRING_AT_LEAST_64_CHARS

ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Database ──────────────────────────────────────────────────
POSTGRES_DB=coverageops
POSTGRES_USER=coverageops
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD

# Full URL (used by backend service)
DATABASE_URL=postgresql://coverageops:REPLACE_WITH_STRONG_DB_PASSWORD@db:5432/coverageops

# ── CORS (comma-separated list of allowed origins) ────────────
# Development:
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
# Production – replace with your actual domain:
# CORS_ORIGINS=["https://coverageops.yourdomain.com"]

# ── Coverage Engine ───────────────────────────────────────────
# Path where SRTM elevation tiles are stored (inside container)
SRTM_DATA_DIR=/data/srtm

# Max radius allowed per analysis request (km)
MAX_ANALYSIS_RADIUS_KM=50.0

# Grid resolution (higher = more detail, slower)
# Recommended: 80 for field use, 150 for detailed analysis
COVERAGE_GRID_RESOLUTION=80

# Path to signal-server binary (optional – for Longley-Rice model)
# SIGNAL_SERVER_BIN=/usr/local/bin/signal-server

# ── Storage ───────────────────────────────────────────────────
# Where GeoJSON result files are stored
RESULTS_DIR=/data/results

# ── Frontend ──────────────────────────────────────────────────
# Development
VITE_API_URL=http://localhost:8000
# Production
# VITE_API_URL=https://coverageops.yourdomain.com
